<ContentDialog
    x:Class="Respatch.Views.Dialogs.AddProjectDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Respatch.Converters"
    Title="Pridať projekt"
    xmlns:viewmodels="using:Respatch.ViewModels"
    PrimaryButtonText=""
    CloseButtonText="Zrušiť"
    DefaultButton="Primary">

    <ContentDialog.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </ContentDialog.Resources>

    <StackPanel Spacing="12" MinWidth="360">

        <!-- Error InfoBar (replaces Adw.ToastOverlay) -->
        <InfoBar
            IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
            Severity="Error"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            IsClosable="False" />

        <!-- Name -->
        <StackPanel Spacing="4">
            <TextBlock x:Uid="ProjectNameLabel" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <TextBox
                Text="{x:Bind ViewModel.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                PlaceholderText="Môj projekt" />
        </StackPanel>

        <!-- URL -->
        <StackPanel Spacing="4">
            <TextBlock x:Uid="ProjectUrlLabel" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <TextBox
                Text="{x:Bind ViewModel.Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                PlaceholderText="https://example.com" />
        </StackPanel>

        <!-- Token -->
        <StackPanel Spacing="4">
            <TextBlock x:Uid="ProjectTokenLabel" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <PasswordBox
                Password="{x:Bind ViewModel.Token, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                PlaceholderText="••••••••" />
        </StackPanel>

        <!-- Action button -->
        <Button
            Content="{x:Bind ViewModel.ActionButtonLabel, Mode=OneWay}"
            Command="{x:Bind ViewModel.ActionCommand}"
            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
            Style="{StaticResource AccentButtonStyle}"
            HorizontalAlignment="Stretch"
            Margin="0,4,0,0" />

    </StackPanel>
</ContentDialog>

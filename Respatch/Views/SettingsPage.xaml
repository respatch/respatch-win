<Page
    x:Class="Respatch.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer Padding="24">
        <StackPanel MaxWidth="600" Spacing="8">

            <TextBlock
                x:Uid="SettingsTitle"
                Style="{StaticResource TitleTextBlockStyle}"
                Margin="0,0,0,16" />

            <!-- Diagnostics group -->
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="16">
                <StackPanel Spacing="0">

                    <TextBlock
                        x:Uid="DiagnosticsGroup"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Margin="0,0,0,12" />

                    <!-- Logging enabled toggle -->
                    <Grid Padding="0,8" MinHeight="48">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                            <TextBlock x:Uid="LoggingEnabledToggle" Style="{StaticResource BodyTextBlockStyle}" />
                        </StackPanel>
                        <ToggleSwitch
                            Grid.Column="1"
                            IsOn="{x:Bind ViewModel.IsLoggingEnabled, Mode=TwoWay}"
                            OffContent=""
                            OnContent=""
                            VerticalAlignment="Center" />
                    </Grid>

                    <MenuFlyoutSeparator />

                    <!-- Log to file toggle (disabled when logging is off) -->
                    <Grid Padding="0,8" MinHeight="48">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                            <TextBlock x:Uid="LogToFileToggle" Style="{StaticResource BodyTextBlockStyle}" />
                        </StackPanel>
                        <ToggleSwitch
                            Grid.Column="1"
                            IsOn="{x:Bind ViewModel.IsLogToFile, Mode=TwoWay}"
                            IsEnabled="{x:Bind ViewModel.IsLogToFileEnabled, Mode=OneWay}"
                            OffContent=""
                            OnContent=""
                            VerticalAlignment="Center" />
                    </Grid>

                    <MenuFlyoutSeparator />

                    <!-- Log file path (read-only) -->
                    <Grid Padding="0,8" MinHeight="48">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                            <TextBlock x:Uid="LogFilePathLabel" Style="{StaticResource BodyTextBlockStyle}" />
                            <TextBlock
                                Text="{x:Bind ViewModel.LogFilePath, Mode=OneTime}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                IsTextSelectionEnabled="True"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
